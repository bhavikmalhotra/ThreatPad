# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/threatpad

# Redis
REDIS_URL=redis://localhost:6379

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-refresh

# OAuth (Google) — optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth (GitHub) — optional
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (Resend) — optional, falls back to console logging
RESEND_API_KEY=
FROM_EMAIL=noreply@threatpad.io

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3000

# Self-hosted mode — skips email verification for new users
SELF_HOSTED=false

# Disable public registration — only invited users can join
DISABLE_REGISTRATION=false

# Restrict registration to specific email domains (comma-separated, empty = allow all)
# Example: ALLOWED_EMAIL_DOMAINS=partner.org
ALLOWED_EMAIL_DOMAINS=

# Frontend env vars (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:3002
